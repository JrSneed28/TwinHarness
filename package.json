{
  "name": "twinharness",
  "version": "0.7.0",
  "description": "TwinHarness — Agentic SDLC Orchestrator. A Claude Code plugin: prompt orchestration (16 specialized agents) plus a deterministic `th` CLI for all mechanical enforcement (state, hashing, anchors, traceability, coverage, drift, cascade-staleness).",
  "type": "commonjs",
  "bin": {
    "th": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "author": "JrSneed28 (https://github.com/JrSneed28)",
  "files": [
    "dist",
    "skills",
    "agents",
    "commands",
    "templates",
    "hooks",
    "schemas",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:mcp",
    "build:mcp": "esbuild src/mcp-server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/mcp-server.js",
    "th": "node dist/cli.js",
    "gen:docs": "npx --yes tsx scripts/gen-command-reference.ts",
    "gen:docs:check": "npx --yes tsx scripts/gen-command-reference.ts --check",
    "test": "vitest run && vitest run --config vitest.stress.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "verify": "npm run typecheck && npm run build && npm test && git diff --exit-code dist/",
    "dist-sync-check": "git diff --exit-code dist/",
    "prepare": "git config core.hooksPath .githooks || exit 0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
