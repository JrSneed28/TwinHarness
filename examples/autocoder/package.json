{
  "name": "autocoder",
  "version": "0.0.0",
  "private": true,
  "description": "Autocoder — autonomous coding-agent CLI (mini Claude Code). Walking-skeleton build.",
  "type": "module",
  "bin": {
    "autocoder": "dist/cli.js"
