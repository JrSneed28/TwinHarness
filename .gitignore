node_modules/
*.log
*.tsbuildinfo

# dist/ is COMMITTED on purpose: Claude Code plugin installs copy this repo
# as-is into the plugin cache (no npm install / build step runs), so the
# compiled `th` CLI must ship in git. After editing src/, run `npm run build`
# and commit the dist/ changes together with the source.

# TwinHarness runtime artifacts (created by `th init` in a TARGET project).
# Tests write these into OS temp dirs, but ignore them at repo root just in case.
/.twinharness/
/.agentic-sdlc/
# Ignore the th-init artifact namespace under docs/ but ship the hand-written
# user guides under docs/guide/. (Ignoring /docs/* rather than /docs/ lets git
# descend so the negation below can re-include the guide subtree.)
/docs/*
!/docs/guide/
/drift-log.md

# Local tooling state (not part of the plugin deliverable). .omc/ is session
# state recreated at runtime by local tooling — never commit it.
.claude/
.omc/
/.case-studies/

# Harness-development artifacts: audit/review reports and session scratch
# produced while developing TwinHarness itself. They are working documents,
# not part of the plugin deliverable (plugin installs copy the repo as-is).
AUDIT.md
/audit*.md
/*-report.md
/scratch/
# Root CLAUDE.md is a local working copy of the project context, not shipped.
/CLAUDE.md

# examples/ are reference projects, not part of the shipped plugin.
/examples/

# Agent session scratch (gjc/ralplan/ultragoal/deep-interview runtime state) —
# recreated at runtime, never part of the plugin deliverable. Same class as .omc/.
.gjc/
